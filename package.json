{
  "name": "rotaposto",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --ip 0.0.0.0 --port 3000",
    "build": "BUILD_TARGET=pages vite build",
    "build:workers": "vite build && echo 'index.js' > dist/.assetsignore",
    "build:pages": "BUILD_TARGET=pages vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "build:pages": "BUILD_TARGET=pages vite build",
    "build:workers": "vite build && echo 'index.js' > dist/.assetsignore",
    "deploy:pages": "npm run build:pages && wrangler pages deploy dist --project-name rotaposto",
    "deploy:workers": "npm run build:workers"
  },
  "dependencies": {
    "hono": "^4.12.26"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.25.2",
    "sharp": "^0.35.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
