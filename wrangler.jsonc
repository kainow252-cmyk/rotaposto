{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rotaposto",
  "pages_build_output_dir": "./dist",
  "compatibility_date": "2026-04-26",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "ROTAPOSTO_KV",
      "id": "9875387ed3434643838b38cf945eccde"
    }
  ],
  // Cron: toda sábado ao meio-dia (UTC) — sincroniza preços ANP da semana
  "triggers": {
    "crons": ["0 12 * * 6"]
  }
}
