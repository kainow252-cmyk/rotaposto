{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rotaposto",
  "pages_build_output_dir": "./dist",
  "compatibility_date": "2026-04-26",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "ROTAPOSTO_KV",
      "id": "9875387ed3434643838b38cf945eccde"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ROTAPOSTO_R2",
      "bucket_name": "rotaposto-kv"
    }
  ]
}
