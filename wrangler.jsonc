{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rotaposto",
  "pages_build_output_dir": "./dist",
  "compatibility_date": "2026-04-26",
  "compatibility_flags": [
    "nodejs_compat"
  ]
  // KV removido: conta hospedada Genspark não usa o mesmo namespace
  // O binding ROTAPOSTO_KV é injetado pela plataforma — getKV() retorna null se ausente
  // e o sistema faz fallback para bundle estático de preços (precos_anp_posto.ts)
}
